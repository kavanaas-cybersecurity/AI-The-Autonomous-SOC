# --- WAZUH CONFIGURATION ---
# The username for your Wazuh Indexer (default is usually 'admin')
WAZUH_USER=admin

# The password for your Wazuh Indexer
WAZUH_PASS=your_wazuh_password_here

# The full URL to your Wazuh Indexer (including port 9200)
INDEXER_URL=https://localhost:9200


# --- JIRA CONFIGURATION ---
# Your Jira Cloud instance URL (e.g., https://your-company.atlassian.net)
JIRA_SERVER=https://your-domain.atlassian.net

# The email address associated with your Atlassian account
JIRA_EMAIL=your-email@example.com

# Your Jira API Token (generated at id.atlassian.com)
JIRA_API_TOKEN=your_jira_api_token_here

# The shorthand Key for your Jira Project (e.g., 'KAN' or 'PROJ')
JIRA_PROJECT_KEY=KAN